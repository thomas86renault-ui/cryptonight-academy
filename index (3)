<script>
/* ================= HERO SCROLL PARALLAX ================= */
(() => {
  const coin = document.getElementById('bitcoin-canvas');
  const bg = document.querySelector('.hero-bg');
  const content = document.querySelector('.hero-content');
  if (!coin) return;
  function update() {
    const y = window.scrollY;
    const vh = window.innerHeight;
    const p = Math.min(1, y / vh);
    coin.style.transform = `translate(-50%, calc(-50% - ${p * 160}px)) scale(${1 - p * 0.15}) rotate(${p * 8}deg)`;
    coin.style.opacity = 1 - p * 0.9;
    if (bg) bg.style.transform = `translateY(${p * 80}px) scale(${1 + p * 0.05})`;
    if (content) {
      content.style.transform = `translateY(${p * 60}px)`;
      content.style.opacity = 1 - p * 1.1;
    }
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ================= CUSTOM CURSOR ================= */
(() => {
  const c = document.getElementById('cursor');
  const d = document.getElementById('cursor-dot');
  if (!c) return;
  let x = 0, y = 0, tx = 0, ty = 0;
  c.style.opacity = '0'; d.style.opacity = '0';
  window.addEventListener('mousemove', e => {
    tx = e.clientX; ty = e.clientY;
    d.style.left = tx + 'px'; d.style.top = ty + 'px';
    c.style.opacity = '1'; d.style.opacity = '1';
  });
  document.addEventListener('mouseleave', () => { c.style.opacity = '0'; d.style.opacity = '0'; });
  document.addEventListener('mouseenter', () => { c.style.opacity = '1'; d.style.opacity = '1'; });
  function loop() {
    x += (tx - x) * 0.15; y += (ty - y) * 0.15;
    c.style.left = x + 'px'; c.style.top = y + 'px';
    requestAnimationFrame(loop);
  }
  loop();
  document.querySelectorAll('a, button, .service-card, .gallery-item').forEach(el => {
    el.addEventListener('mouseenter', () => c.classList.add('hover'));
    el.addEventListener('mouseleave', () => c.classList.remove('hover'));
  });
})();

/* ================= HERO TITLE CHAR STAGGER ================= */
(() => {
  const chars = document.querySelectorAll('#hero-title .char');
  chars.forEach((c, i) => c.style.animationDelay = (0.6 + i * 0.04) + 's');
})();

/* ================= BITCOIN REALISTIC COIN ================= */
(() => {
  const canvas = document.getElementById('bitcoin-canvas');
  if (!canvas) return;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  const CW = 520, CH = 520;
  canvas.width = CW * DPR; canvas.height = CH * DPR;
  canvas.style.width = CW + 'px'; canvas.style.height = CH + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(DPR, DPR);
  const cx = CW/2, cy = CH/2;
  const R = 180;

  // mouse parallax
  let tgtTiltX = 0, tgtTiltY = 0, tiltX = 0, tiltY = 0;
  window.addEventListener('mousemove', e => {
    const mx = (e.clientX / window.innerWidth - 0.5);
    const my = (e.clientY / window.innerHeight - 0.5);
    tgtTiltY = mx * 0.6;
    tgtTiltX = -my * 0.4;
  });

  // scroll energy — coin spins faster as user scrolls
  let scrollEnergy = 0;
  let lastScroll = window.scrollY;
  window.addEventListener('scroll', () => {
    const dy = window.scrollY - lastScroll;
    scrollEnergy = Math.min(0.2, scrollEnergy + Math.abs(dy) * 0.0008);
    lastScroll = window.scrollY;
  }, { passive: true });

  // continuous spin angle
  let spinY = 0;
  let spinSpeed = 0.035; // base speed — always visibly rotating

  // Draw the engraved ₿ glyph — shared helper, applies to whatever face is visible
  function engraveSymbol(symbol, flip, faceScaleX, faceScaleY, colorDark, colorBright) {
    ctx.save();
    ctx.translate(cx, cy);
    ctx.scale(faceScaleX * (flip ? -1 : 1), faceScaleY);
    ctx.font = '900 280px "Arial Black", Arial, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    // engraved shadow
    ctx.fillStyle = 'rgba(20,12,3,0.9)';
    ctx.fillText(symbol, 3, 5);
    // main body
    const bG = ctx.createLinearGradient(0, -130, 0, 130);
    bG.addColorStop(0, colorBright);
    bG.addColorStop(0.5, '#d0a565');
    bG.addColorStop(1, colorDark);
    ctx.fillStyle = bG;
    ctx.fillText(symbol, 0, 0);
    // top highlight
    ctx.fillStyle = 'rgba(255,245,215,0.35)';
    ctx.fillText(symbol, -1, -2);
    ctx.restore();
  }

  function draw() {
    // Accumulate speed from scroll, decay back to base
    spinSpeed += (0.035 + scrollEnergy - spinSpeed) * 0.05;
    scrollEnergy *= 0.92;
    spinY += spinSpeed;

    tiltX += (tgtTiltX - tiltX) * 0.05;
    tiltY += (tgtTiltY - tiltY) * 0.05;
    // breathing tilt
    const t = performance.now() * 0.0006;
    const tx = tiltX + Math.cos(t * 0.7) * 0.05;
    const ty_extra = tiltY;
    // combine spin with mouse tilt for Y
    const yAngle = spinY + ty_extra;

    ctx.clearRect(0, 0, CW, CH);

    // effective ellipse radii
    const rx = R * Math.abs(Math.cos(yAngle));
    const ry = R * Math.cos(tx);
    const isFront = Math.cos(yAngle) >= 0; // true = showing front face

    // ===== ambient glow =====
    const glow = ctx.createRadialGradient(cx, cy, R*0.6, cx, cy, R*1.9);
    glow.addColorStop(0, 'rgba(201, 169, 110, 0.3)');
    glow.addColorStop(0.5, 'rgba(201, 169, 110, 0.08)');
    glow.addColorStop(1, 'rgba(201, 169, 110, 0)');
    ctx.fillStyle = glow;
    ctx.beginPath(); ctx.arc(cx, cy, R*1.9, 0, Math.PI*2); ctx.fill();

    // ===== drop shadow =====
    ctx.save();
    ctx.translate(cx, cy + R*0.75);
    ctx.scale(1, 0.22);
    const sh = ctx.createRadialGradient(0, 0, 0, 0, 0, R*1.2);
    sh.addColorStop(0, 'rgba(0,0,0,0.55)');
    sh.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = sh;
    ctx.beginPath(); ctx.arc(0, 0, R*1.2, 0, Math.PI*2); ctx.fill();
    ctx.restore();

    // ===== edge band (coin thickness) =====
    // offset back ellipse in direction opposite to sin(yAngle)
    const thick = 14;
    const sinY = Math.sin(yAngle);
    const backDx = sinY * thick;
    const backDy = -Math.sin(tx) * thick;
    ctx.save();
    ctx.fillStyle = '#4a3619';
    ctx.beginPath(); ctx.ellipse(cx - backDx, cy + backDy, rx, ry, 0, 0, Math.PI*2); ctx.fill();

    // Draw the edge as a polygon hull between front + back ellipses (handles any rotation)
    const steps = 72;
    const frontPts = [], backPts = [];
    for (let i = 0; i < steps; i++) {
      const a = (i/steps) * Math.PI * 2;
      frontPts.push({ x: cx + Math.cos(a) * rx, y: cy + Math.sin(a) * ry });
      backPts.push({ x: cx - backDx + Math.cos(a) * rx, y: cy + backDy + Math.sin(a) * ry });
    }
    // edge gradient varies with rotation
    const rim = ctx.createLinearGradient(cx - rx, cy, cx + rx, cy);
    rim.addColorStop(0, '#2a1f0d');
    rim.addColorStop(0.2, '#8a6a32');
    rim.addColorStop(0.5, '#f2d89a');
    rim.addColorStop(0.8, '#8a6a32');
    rim.addColorStop(1, '#2a1f0d');
    ctx.fillStyle = rim;
    // draw filled hull of front+back outlines
    ctx.beginPath();
    // Go around combined convex hull by splitting into 2 quads per segment
    for (let i = 0; i < steps; i++) {
      const n = (i+1) % steps;
      ctx.moveTo(backPts[i].x, backPts[i].y);
      ctx.lineTo(backPts[n].x, backPts[n].y);
      ctx.lineTo(frontPts[n].x, frontPts[n].y);
      ctx.lineTo(frontPts[i].x, frontPts[i].y);
      ctx.closePath();
    }
    ctx.fill();

    // reeded edge ticks
    ctx.strokeStyle = 'rgba(0,0,0,0.55)';
    ctx.lineWidth = 1;
    for (let i = 0; i < steps; i++) {
      const edgeFactor = Math.abs(Math.sin((i/steps) * Math.PI * 2));
      if (edgeFactor > 0.55) {
        ctx.globalAlpha = (edgeFactor - 0.55) * 2.2;
        ctx.beginPath();
        ctx.moveTo(backPts[i].x, backPts[i].y);
        ctx.lineTo(frontPts[i].x, frontPts[i].y);
        ctx.stroke();
      }
    }
    ctx.globalAlpha = 1;
    ctx.restore();

    // ===== front face (or back face, same treatment — just different symbol) =====
    ctx.save();
    ctx.beginPath(); ctx.ellipse(cx, cy, rx, ry, 0, 0, Math.PI*2); ctx.clip();

    // base metallic gradient
    const base = ctx.createRadialGradient(cx - rx*0.35, cy - ry*0.4, rx*0.08, cx + rx*0.2, cy + ry*0.4, rx*1.3);
    base.addColorStop(0, '#fff4d0');
    base.addColorStop(0.2, '#f0d495');
    base.addColorStop(0.5, '#c9a96e');
    base.addColorStop(0.8, '#6b4f22');
    base.addColorStop(1, '#2a1c08');
    ctx.fillStyle = base;
    ctx.fillRect(cx - rx - 2, cy - ry - 2, rx*2 + 4, ry*2 + 4);

    // bezel rings
    ctx.strokeStyle = 'rgba(30,18,4,0.6)';
    ctx.lineWidth = 3;
    ctx.beginPath(); ctx.ellipse(cx, cy, rx*0.93, ry*0.93, 0, 0, Math.PI*2); ctx.stroke();
    ctx.strokeStyle = 'rgba(255,230,180,0.5)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.ellipse(cx, cy, rx*0.93 - 2.5, ry*0.93 - 2.5, 0, 0, Math.PI*2); ctx.stroke();
    ctx.strokeStyle = 'rgba(30,18,4,0.5)';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.ellipse(cx, cy, rx*0.85, ry*0.85, 0, 0, Math.PI*2); ctx.stroke();

    // decorative dots on rim
    for (let i = 0; i < 28; i++) {
      const a = (i/28) * Math.PI*2;
      const sx = cx + Math.cos(a) * rx*0.89;
      const sy = cy + Math.sin(a) * ry*0.89;
      ctx.fillStyle = 'rgba(40,25,5,0.7)';
      ctx.beginPath(); ctx.arc(sx, sy, 1.3, 0, Math.PI*2); ctx.fill();
    }

    // symbol depends on face: ₿ on front, N on back (CryptoNight mark)
    const faceScaleX = Math.max(0.02, Math.abs(Math.cos(yAngle)));
    const faceScaleY = Math.max(0.02, Math.cos(tx));
    if (isFront) {
      engraveSymbol('₿', false, faceScaleX, faceScaleY, '#7a5520', '#f8e2a8');
    } else {
      // back face: CryptoNight N (stylized)
      ctx.save();
      ctx.translate(cx, cy);
      ctx.scale(faceScaleX, faceScaleY);
      ctx.font = '200 italic 220px "Cormorant Garamond", serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillStyle = 'rgba(20,12,3,0.9)';
      ctx.fillText('N', 3, 5);
      const nG = ctx.createLinearGradient(0, -100, 0, 100);
      nG.addColorStop(0, '#f8e2a8'); nG.addColorStop(1, '#7a5520');
      ctx.fillStyle = nG;
      ctx.fillText('N', 0, 0);
      // decorative rings around N
      ctx.strokeStyle = 'rgba(40,25,5,0.7)';
      ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(0, 0, 130, 0, Math.PI*2); ctx.stroke();
      // text around
      ctx.font = '500 16px Montserrat, sans-serif';
      ctx.fillStyle = 'rgba(40,25,5,0.75)';
      const label = 'CRYPTO · NIGHT · XX · ';
      for (let i = 0; i < label.length; i++) {
        const a = (i / label.length) * Math.PI * 2 - Math.PI/2;
        ctx.save();
        ctx.rotate(a);
        ctx.translate(0, -148);
        ctx.fillText(label[i], 0, 0);
        ctx.restore();
      }
      ctx.restore();
    }

    // specular sweep
    const gloss = ctx.createLinearGradient(cx - rx, cy - ry, cx + rx*0.4, cy + ry*0.3);
    gloss.addColorStop(0, 'rgba(255,250,230,0.4)');
    gloss.addColorStop(0.4, 'rgba(255,250,230,0.05)');
    gloss.addColorStop(0.7, 'rgba(0,0,0,0)');
    gloss.addColorStop(1, 'rgba(0,0,0,0.3)');
    ctx.fillStyle = gloss;
    ctx.fillRect(cx - rx, cy - ry, rx*2, ry*2);

    // moving highlight that travels with rotation
    const hlPhase = yAngle * 0.5;
    const hx = cx + Math.cos(hlPhase) * rx*0.35 - rx*0.15;
    const hy = cy - ry*0.3;
    const hl = ctx.createRadialGradient(hx, hy, 0, hx, hy, rx*0.8);
    hl.addColorStop(0, 'rgba(255,250,225,0.55)');
    hl.addColorStop(0.4, 'rgba(255,250,225,0.08)');
    hl.addColorStop(1, 'rgba(255,250,225,0)');
    ctx.globalCompositeOperation = 'screen';
    ctx.fillStyle = hl;
    ctx.fillRect(cx - rx, cy - ry, rx*2, ry*2);
    ctx.globalCompositeOperation = 'source-over';

    // inner vignette
    ctx.globalCompositeOperation = 'multiply';
    const vg = ctx.createRadialGradient(cx, cy, rx*0.5, cx, cy, rx*1.02);
    vg.addColorStop(0, 'rgba(255,255,255,1)');
    vg.addColorStop(1, 'rgba(110,75,30,1)');
    ctx.fillStyle = vg;
    ctx.fillRect(cx - rx, cy - ry, rx*2, ry*2);
    ctx.globalCompositeOperation = 'source-over';

    ctx.restore();

    requestAnimationFrame(draw);
  }
  draw();
})();



/* ================= PARTICLES ================= */
(() => {
  const canvas = document.getElementById('particles-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  const particles = Array.from({length: 80}, () => ({
    x: Math.random() * W,
    y: Math.random() * H,
    r: Math.random() * 1.5 + 0.3,
    vx: (Math.random() - 0.5) * 0.2,
    vy: -Math.random() * 0.4 - 0.1,
    a: Math.random() * 0.5 + 0.2,
    t: Math.random() * Math.PI * 2
  }));
  function tick() {
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => {
      p.t += 0.02;
      p.x += p.vx + Math.sin(p.t) * 0.15;
      p.y += p.vy;
      if (p.y < -10) { p.y = H + 10; p.x = Math.random() * W; }
      if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
      const alpha = p.a * (0.5 + 0.5 * Math.sin(p.t));
      ctx.fillStyle = `rgba(201, 169, 110, ${alpha})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
      // glow
      ctx.fillStyle = `rgba(201, 169, 110, ${alpha * 0.15})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 4, 0, Math.PI * 2);
      ctx.fill();
    });
    requestAnimationFrame(tick);
  }
  tick();
})();

/* ================= MANIFESTO WORDS REVEAL ================= */
(() => {
  const q = document.getElementById('manifesto-quote');
  if (!q) return;
  // Array of [word, isItalic]
  const tokens = [
    ["Nous",0],["ne",0],["vendons",0],["pas",0],["des",0],["signaux.",0],
    ["Nous",0],["vendons",0],["vingt",0],["minutes",0],["de",0],["clarté,",0],
    ["quand",0],["les",0],["autres",0],["scrollent",0],["dans",0],["le",0],["bruit.",0],
    ["Chaque",1],["soir,",1],["à",1],["vingt",1],["heures,",1],
    ["un",0],["briefing.",0],["Une",0],["direction.",0],["Une",0],["discipline.",0]
  ];
  q.innerHTML = tokens.map(([w, it]) =>
    it ? `<span class="w"><em>${w}</em></span>` : `<span class="w">${w}</span>`
  ).join(' ');
  const words = q.querySelectorAll('.w');
  // scroll-driven word reveal
  function onScroll() {
    const rect = q.getBoundingClientRect();
    const vh = window.innerHeight;
    // progress from when top enters view to when bottom exits
    const start = vh * 0.9;
    const end = vh * 0.2;
    const prog = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
    const lit = Math.floor(prog * words.length);
    words.forEach((w, i) => w.classList.toggle('lit', i < lit));
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();

