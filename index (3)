<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CryptoNight — L'argent n'attend pas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,200;0,300;0,400;1,200;1,300;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --black: #020202;
  --black-soft: #0a0a0a;
  --gold: #C9A96E;
  --gold-soft: #a68b58;
  --gold-bright: #e0c48a;
  --white: #F5F0E8;
  --white-dim: rgba(245, 240, 232, 0.6);
  --serif: 'Cormorant Garamond', serif;
  --sans: 'Montserrat', sans-serif;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
  background: var(--black);
  color: var(--white);
  font-family: var(--sans);
  font-weight: 300;
  overflow-x: hidden;
  scroll-behavior: smooth;
}

body {
  cursor: none;
}

@media (max-width: 768px) {
  body { cursor: auto; }
  .cursor, .cursor-dot { display: none !important; }
}

/* ================= NOISE OVERLAY ================= */
.noise {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9998;
  opacity: 0.04;
  mix-blend-mode: overlay;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' /%3E%3C/svg%3E");
}

/* ================= CUSTOM CURSOR ================= */
.cursor {
  position: fixed;
  width: 32px;
  height: 32px;
  border: 1px solid var(--gold);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s, border-color 0.3s, background 0.3s;
  mix-blend-mode: difference;
}
.cursor-dot {
  position: fixed;
  width: 4px;
  height: 4px;
  background: var(--gold);
  border-radius: 50%;
  pointer-events: none;
  z-index: 10000;
  transform: translate(-50%, -50%);
  transition: width 0.2s, height 0.2s;
}
.cursor.hover {
  width: 64px;
  height: 64px;
  background: rgba(201, 169, 110, 0.1);
}

/* ================= NAVIGATION ================= */
nav.topnav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28px 48px;
  mix-blend-mode: difference;
}
.brand {
  font-family: var(--serif);
  font-weight: 300;
  font-size: 20px;
  letter-spacing: 0.3em;
  color: var(--white);
}
.brand em { color: var(--gold); font-style: italic; font-weight: 200; }
.nav-links {
  display: flex;
  gap: 36px;
  font-size: 11px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
}
.nav-links a {
  color: var(--white);
  text-decoration: none;
  opacity: 0.7;
  transition: opacity 0.3s, color 0.3s;
}
.nav-links a:hover { opacity: 1; color: var(--gold); }
@media (max-width: 768px) {
  nav.topnav { padding: 20px 24px; }
  .nav-links { display: none; }
}

/* ================= HERO ================= */
section.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('https://images.unsplash.com/photo-1540541338287-41700207dee6?w=2000&q=90');
  background-size: cover;
  background-position: center;
  filter: brightness(0.55) contrast(1.08) saturate(1.05);
  will-change: transform;
}
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 80% at center, transparent 0%, rgba(2,2,2,0.4) 40%, var(--black) 95%);
}
.hero-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(2,2,2,0.3) 0%, rgba(2,2,2,0.1) 50%, var(--black) 100%);
  z-index: 1;
}
#bitcoin-canvas {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  pointer-events: none;
}
#particles-canvas {
  position: absolute;
  inset: 0;
  z-index: 3;
  pointer-events: none;
}
.hero-content {
  position: relative;
  z-index: 4;
  text-align: center;
  padding: 0 24px;
}
.hero-kicker {
  font-size: 10px;
  letter-spacing: 0.6em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 32px;
  opacity: 0;
  animation: fadeIn 1.5s 0.3s forwards;
}
.hero-kicker::before, .hero-kicker::after {
  content: '—';
  margin: 0 16px;
  opacity: 0.5;
}
h1.hero-title {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(48px, 9vw, 140px);
  line-height: 1;
  letter-spacing: -0.02em;
  margin-bottom: 40px;
}
h1.hero-title .word {
  display: inline-block;
  margin-right: 0.2em;
}
h1.hero-title .char {
  display: inline-block;
  opacity: 0;
  transform: translateY(60px);
  animation: charIn 0.8s forwards;
}
h1.hero-title em {
  font-style: italic;
  color: var(--gold);
  font-weight: 200;
}
@keyframes charIn {
  to { opacity: 1; transform: translateY(0); }
}
.hero-sub {
  font-size: 14px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--white-dim);
  margin-bottom: 64px;
  opacity: 0;
  animation: fadeIn 1.5s 1.8s forwards;
}
.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  padding: 18px 40px;
  border: 1px solid var(--gold);
  color: var(--white);
  text-decoration: none;
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  opacity: 0;
  animation: fadeIn 1.5s 2.1s forwards;
  transition: all 0.4s;
  position: relative;
  overflow: hidden;
}
.hero-cta span { position: relative; z-index: 2; }
.hero-cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gold);
  transform: translateX(-101%);
  transition: transform 0.5s cubic-bezier(0.7, 0, 0.3, 1);
  z-index: 1;
}
.hero-cta:hover::before { transform: translateX(0); }
.hero-cta:hover { color: var(--black); }
.hero-cta .arrow { font-family: var(--serif); font-size: 18px; }

.scroll-hint {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
  font-size: 10px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0;
  animation: fadeIn 2s 2.5s forwards, pulse 2s 2.5s infinite;
}
.scroll-hint::after {
  content: '';
  display: block;
  width: 1px;
  height: 40px;
  background: var(--gold);
  margin: 16px auto 0;
  animation: scrollLine 2s infinite;
  transform-origin: top;
}
@keyframes scrollLine {
  0% { transform: scaleY(0); }
  50% { transform: scaleY(1); }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
@keyframes fadeIn { to { opacity: 1; } }
@keyframes pulse { 0%, 100% { opacity: 0.8; } 50% { opacity: 0.3; } }

/* ================= SECTION BASE ================= */
section.block {
  position: relative;
  padding: 160px 48px;
  min-height: 100vh;
}
@media (max-width: 768px) {
  section.block { padding: 100px 24px; }
}
.eyebrow {
  font-size: 10px;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.eyebrow::before {
  content: '';
  width: 40px;
  height: 1px;
  background: var(--gold);
}
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 1.2s cubic-bezier(0.25, 0.8, 0.25, 1), transform 1.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.reveal.in {
  opacity: 1;
  transform: translateY(0);
}

/* ================= MANIFESTO ================= */
.manifesto {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--black);
}
.manifesto::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(201, 169, 110, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(201, 169, 110, 0.06) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  animation: gridShift 20s linear infinite;
}
@keyframes gridShift {
  from { background-position: 0 0, 0 0; }
  to { background-position: 80px 80px, 80px 80px; }
}
.manifesto-inner {
  max-width: 1100px;
  text-align: center;
  position: relative;
  z-index: 2;
}
.manifesto-quote {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(36px, 5.5vw, 80px);
  line-height: 1.15;
  letter-spacing: -0.01em;
  margin-bottom: 80px;
}
.manifesto-quote em { font-style: italic; color: var(--gold); font-weight: 200; }
.manifesto-quote .w {
  display: inline-block;
  opacity: 0.15;
  transition: opacity 0.6s, color 0.6s;
  margin-right: 0.25em;
}
.manifesto-quote .w.lit { opacity: 1; }

.counters {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  padding-top: 60px;
  border-top: 1px solid rgba(201, 169, 110, 0.2);
}
@media (max-width: 640px) { .counters { grid-template-columns: 1fr; gap: 32px; } }
.counter {
  text-align: center;
}
.counter-num {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(56px, 8vw, 120px);
  color: var(--gold);
  line-height: 1;
  margin-bottom: 12px;
}
.counter-label {
  font-size: 10px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--white-dim);
}

/* ================= IMMERSION 360 ================= */
.immersion {
  background: var(--black);
  padding: 0;
  min-height: auto;
}
.immersion-header {
  padding: 120px 48px 80px;
  text-align: center;
}
.immersion-title {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(40px, 6vw, 84px);
  line-height: 1.05;
  margin-bottom: 24px;
}
.immersion-title em { font-style: italic; color: var(--gold); }
.immersion-desc {
  max-width: 560px;
  margin: 0 auto;
  font-size: 15px;
  line-height: 1.7;
  color: var(--white-dim);
}

.gallery-track {
  display: flex;
  gap: 32px;
  padding: 0 48px 48px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
}
.gallery-track::-webkit-scrollbar { display: none; }
.gallery-item {
  flex: 0 0 78vw;
  max-width: 1200px;
  aspect-ratio: 16/10;
  scroll-snap-align: center;
  position: relative;
  overflow: hidden;
  cursor: none;
}
@media (max-width: 768px) {
  .gallery-track { padding: 0 24px 32px; gap: 16px; }
  .gallery-item { flex: 0 0 88vw; aspect-ratio: 3/4; }
  .immersion-header { padding: 80px 24px 48px; }
}
.gallery-item img {
  position: absolute;
  inset: -10% -10%;
  width: 120%;
  height: 120%;
  object-fit: cover;
  transition: transform 1.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  filter: brightness(0.7) contrast(1.05);
}
.gallery-item:hover img { transform: scale(1.08); }
.gallery-item::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 40%, rgba(2,2,2,0.85) 100%);
  z-index: 1;
}
.gallery-caption {
  position: absolute;
  bottom: 48px;
  left: 48px;
  right: 48px;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24px;
}
.gallery-caption .num {
  font-family: var(--serif);
  font-weight: 200;
  font-size: 14px;
  letter-spacing: 0.2em;
  color: var(--gold);
}
.gallery-caption h3 {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(28px, 4vw, 56px);
  line-height: 1;
  margin-top: 8px;
}
.gallery-caption h3 em { font-style: italic; color: var(--gold); }
.gallery-caption .tag {
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--white-dim);
  white-space: nowrap;
}
@media (max-width: 640px) {
  .gallery-caption { bottom: 24px; left: 24px; right: 24px; flex-direction: column; align-items: flex-start; }
}

.gallery-progress {
  display: flex;
  justify-content: center;
  gap: 8px;
  padding: 16px 0 80px;
}
.gallery-progress span {
  width: 32px;
  height: 1px;
  background: rgba(201, 169, 110, 0.25);
  transition: background 0.4s;
}
.gallery-progress span.active { background: var(--gold); }

/* ================= SERVICES ================= */
.services {
  background: var(--black);
}
.services-grid {
  max-width: 1200px;
  margin: 80px auto 0;
  display: grid;
  gap: 1px;
  background: rgba(201, 169, 110, 0.15);
  border: 1px solid rgba(201, 169, 110, 0.15);
}
.service-card {
  background: var(--black);
  padding: 48px 56px;
  cursor: none;
  transition: background 0.6s;
  position: relative;
  overflow: hidden;
}
.service-card:hover {
  background: #060606;
}
.service-head {
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  gap: 40px;
  align-items: center;
}
@media (max-width: 768px) {
  .service-card { padding: 32px 24px; }
  .service-head { grid-template-columns: auto 1fr; gap: 16px 20px; }
  .service-head .price { grid-column: 2; text-align: left; }
  .service-head .arrow { display: none; }
}
.service-num {
  font-family: var(--serif);
  font-weight: 200;
  font-size: 14px;
  letter-spacing: 0.2em;
  color: var(--gold);
  opacity: 0.6;
}
.service-title {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(24px, 3vw, 36px);
}
.service-title em { font-style: italic; color: var(--gold); }
.price {
  font-family: var(--serif);
  font-weight: 200;
  font-size: 32px;
  color: var(--gold);
}
.price .cents { font-size: 18px; opacity: 0.7; }
.price .unit { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--white-dim); margin-left: 8px; font-family: var(--sans); }
.service-card .arrow {
  font-family: var(--serif);
  font-size: 28px;
  color: var(--gold);
  transform: rotate(-45deg);
  transition: transform 0.4s;
}
.service-card:hover .arrow { transform: rotate(0deg); }
.service-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.service-card:hover .service-body { max-height: 400px; }
.service-body-inner {
  padding-top: 32px;
  margin-top: 32px;
  border-top: 1px solid rgba(201, 169, 110, 0.15);
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 48px;
}
@media (max-width: 768px) { .service-body-inner { grid-template-columns: 1fr; gap: 24px; } }
.service-desc {
  font-size: 15px;
  line-height: 1.8;
  color: var(--white-dim);
}
.service-features {
  list-style: none;
  font-size: 13px;
  line-height: 2;
}
.service-features li {
  padding-left: 24px;
  position: relative;
  color: var(--white-dim);
}
.service-features li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--gold);
}

.ripple-btn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  margin-top: 24px;
  padding: 14px 28px;
  background: transparent;
  border: 1px solid var(--gold);
  color: var(--white);
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  cursor: none;
  position: relative;
  overflow: hidden;
  text-decoration: none;
  transition: color 0.4s;
}
.ripple-btn .ripple {
  position: absolute;
  border-radius: 50%;
  background: rgba(201, 169, 110, 0.4);
  transform: scale(0);
  animation: ripple 0.8s ease-out;
  pointer-events: none;
}
@keyframes ripple {
  to { transform: scale(4); opacity: 0; }
}
.ripple-btn:hover { background: var(--gold); color: var(--black); }

/* ================= VISION ================= */
.vision {
  position: relative;
  background: var(--black);
  overflow: hidden;
}
#constellation-canvas {
  position: absolute;
  inset: 0;
  z-index: 1;
  opacity: 0.5;
}
.vision-inner {
  position: relative;
  z-index: 2;
  max-width: 980px;
  margin: 0 auto;
}
.vision-text {
  font-family: var(--serif);
  font-weight: 200;
  font-size: clamp(28px, 4vw, 54px);
  line-height: 1.25;
  letter-spacing: -0.01em;
}
.vision-text em { font-style: italic; color: var(--gold); }
.vision-text .w {
  display: inline-block;
  opacity: 0.1;
  transition: opacity 0.8s;
  margin-right: 0.22em;
}
.vision-text .w.lit { opacity: 1; }

.signature {
  margin-top: 80px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 40px;
  border-top: 1px solid rgba(201, 169, 110, 0.2);
  flex-wrap: wrap;
  gap: 24px;
}
.signature-name {
  font-family: var(--serif);
  font-style: italic;
  font-weight: 200;
  font-size: 28px;
  color: var(--gold);
}
.signature-role {
  font-size: 10px;
