/* ================= REVEAL ON SCROLL ================= */
(() => {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
})();

/* ================= COUNTERS ================= */
(() => {
  const counters = document.querySelectorAll('[data-target]');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target;
      const target = +el.dataset.target;
      const suffix = el.dataset.suffix || '';
      let n = 0;
      const step = target / 40;
      const tick = () => {
        n += step;
        if (n >= target) { el.textContent = target + suffix; return; }
        el.textContent = Math.floor(n) + suffix;
        requestAnimationFrame(tick);
      };
      tick();
      obs.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => obs.observe(c));
})();

/* ================= GALLERY PROGRESS ================= */
(() => {
  const track = document.getElementById('gallery');
  const dots = document.querySelectorAll('#gallery-progress span');
  if (!track) return;
  track.addEventListener('scroll', () => {
    const items = track.querySelectorAll('.gallery-item');
    const mid = track.scrollLeft + track.clientWidth / 2;
    let closest = 0, best = Infinity;
    items.forEach((it, i) => {
      const c = it.offsetLeft + it.offsetWidth / 2;
      const d = Math.abs(c - mid);
      if (d < best) { best = d; closest = i; }
    });
    dots.forEach((d, i) => d.classList.toggle('active', i === closest));
  }, { passive: true });

  // parallax image zoom on scroll
  track.addEventListener('scroll', () => {
    const items = track.querySelectorAll('.gallery-item img');
    items.forEach(img => {
      const r = img.parentElement.getBoundingClientRect();
      const center = window.innerWidth / 2;
      const imgCenter = r.left + r.width / 2;
      const offset = (imgCenter - center) / window.innerWidth;
      img.style.transform = `translateX(${-offset * 40}px) scale(1.05)`;
    });
  }, { passive: true });
})();

/* ================= CONSTELLATION ================= */
(() => {
  const canvas = document.getElementById('constellation-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  const stars = Array.from({length: 120}, () => ({
    x: Math.random() * W,
    y: Math.random() * H,
    r: Math.random() * 1.2 + 0.2,
    vx: (Math.random() - 0.5) * 0.08,
    vy: (Math.random() - 0.5) * 0.08,
    tw: Math.random() * Math.PI * 2
  }));
  function tick() {
    ctx.clearRect(0, 0, W, H);
    // lines
    for (let i = 0; i < stars.length; i++) {
      for (let j = i+1; j < stars.length; j++) {
        const a = stars[i], b = stars[j];
        const dx = a.x-b.x, dy = a.y-b.y;
        const d = Math.hypot(dx, dy);
        if (d < 140) {
          ctx.strokeStyle = `rgba(201, 169, 110, ${(1 - d/140) * 0.12})`;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }
    }
    stars.forEach(s => {
      s.x += s.vx; s.y += s.vy; s.tw += 0.03;
      if (s.x < 0 || s.x > W) s.vx *= -1;
      if (s.y < 0 || s.y > H) s.vy *= -1;
      const a = 0.4 + 0.4 * Math.sin(s.tw);
      ctx.fillStyle = `rgba(245, 240, 232, ${a})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    });
    requestAnimationFrame(tick);
  }
  tick();
})();

/* ================= COUNTDOWN TO 20:00 ================= */
(() => {
  const h = document.getElementById('c-h');
  const m = document.getElementById('c-m');
  const s = document.getElementById('c-s');
  function pad(n) { return n.toString().padStart(2, '0'); }
  function tick() {
    const now = new Date();
    const target = new Date(now);
    target.setHours(20, 0, 0, 0);
    if (now >= target) target.setDate(target.getDate() + 1);
    const diff = target - now;
    const hh = Math.floor(diff / 3600000);
    const mm = Math.floor((diff % 3600000) / 60000);
    const ss = Math.floor((diff % 60000) / 1000);
    h.textContent = pad(hh);
    m.textContent = pad(mm);
    s.textContent = pad(ss);
  }
  tick();
  setInterval(tick, 1000);
})();

/* ================= RIPPLE BUTTONS ================= */
(() => {
  document.querySelectorAll('[data-ripple]').forEach(btn => {
    btn.addEventListener('click', e => {
      const rect = btn.getBoundingClientRect();
      const r = document.createElement('span');
      r.className = 'ripple';
      const size = Math.max(rect.width, rect.height);
      r.style.width = r.style.height = size + 'px';
      r.style.left = (e.clientX - rect.left - size/2) + 'px';
      r.style.top = (e.clientY - rect.top - size/2) + 'px';
      btn.appendChild(r);
      setTimeout(() => r.remove(), 800);
    });
  });
})();
